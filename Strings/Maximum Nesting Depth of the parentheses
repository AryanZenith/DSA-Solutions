class Solution {
public:
    int maxDepth(string s) {
     int   currentdepth=0;
       int  maxdepth=0;
        for(int i=0;i<s.size();i++){
            if(s[i]=='('){
                currentdepth++;
                maxdepth=max(currentdepth,maxdepth);
            }
            else if(s[i]==')'){
                currentdepth--;
            }
        }
        return maxdepth;
    }
};
