class Solution {
public:
    bool isAnagram(string s, string t) {
        unordered_map<char,int>mp;
        unordered_map<char,int>mp2;
        if(s.size()!=t.size()){
            return false;
        }
        for(int i=0;i<=s.size();i++){
            mp[s[i]]++;
        }
        for(int j=0;j<=t.size();j++){
            mp2[t[j]]++;
        }
       if(mp==mp2){
        return true;
       }
       return false;
    }
};
