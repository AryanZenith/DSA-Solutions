class Solution {
public:
    int findKthPositive(vector<int>& arr, int k) {
        int number=1;
        int count=0;
        int index=0;
        while(count<k){
            if(index<arr.size() && arr[index]==number){
                index++;
            }
            else{
                count++;
                if(count==k){
                    return number;
                }
            }
           number++;
        
        }
       
        return number;
    }
};
